#!/usr/bin/env bash

: ${NUMBER=10}
: ${TARGET=}

while getopts :n:t: OPT; do
  case ${OPT} in
    n) NUMBER="${OPTARG}";;
    t) TARGET="${OPTARG}";;
  esac
done

tmux list-panes -a -F "#S:#I.#P #W #T" | while read -r target_pane window_name pane_title; do
  if [ -n "${TARGET}" ]; then
    case "${target_pane}" in
      ${TARGET}) ;;
      *) continue;;
    esac
  fi

  printf \
    '\033[47m   \033[46m%s\033[47m   \033[46m%s\033[47m   \033[46m%s\033[47m                  \033[0m\n' \
    "${target_pane}" "${window_name}" "${pane_title}"
  tmux capture-pane -t "${target_pane}" -S "-${NUMBER}" -E "-" -e -p | awk '/^$/ { n++; next } { for(i=0; i<n; i++) print ""; print; n=0 }' | tail -n "${NUMBER}"
  printf '\n'
done
